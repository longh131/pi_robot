# DeepSeek API
DEEPSEEK_API_KEY=sk-5e3911cffe7a4aee8d6cbccd4b2419da
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen3 API
DASHSCOPE_API_KEY=sk-49efecd0e118418182273ba0039581ec
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 语音识别模型
ASR_MODEL=paraformer-realtime-v2

# TTS 模型配置
TTS_MODEL=qwen3-tts-flash-2025-09-18
TTS_VOICE=Cherry #萌宝Bella明确的童声音色;茉兔Momo听起来充满活力、活泼可爱;顽屁小孩Pip顽皮小孩风格;乖小妹Mia少女风格;萌小姬Bunny听起来可爱生动

# VAD 阈值设置 (秒)
VAD_EMERGENCY_TIMEOUT=0.3
VAD_NORMAL_TIMEOUT=1.5


# GPIO 引脚配置（L298N）

# 电机
MOTOR_LEFT_FORWARD=17
MOTOR_LEFT_BACKWARD=18
MOTOR_RIGHT_FORWARD=27
MOTOR_RIGHT_BACKWARD=22
MOTOR_LEFT_PWM=19
MOTOR_RIGHT_PWM=26

# 电机速度
MOTOR_SPEED=0.8

# 舵机
SERVO_HEAD=23

# 超声波传感器
ULTRASONIC_TRIG=24
ULTRASONIC_ECHO=25
ULTRASONIC_SAFE_DISTANCE=25 # 安全距离 单位：厘米

# LED 状态指示
LED_PIN=16
LED_DEFAULT_STATE=OFF

# 蜂鸣器
BUZZER_PIN=12
BUZZER_DEFAULT_STATE=OFF

# 音频配置
AUDIO_DEVICE=plughw:2,0  # 录音设备，可用 arecord -l 查看
AUDIO_RATE=44100         # 采样率
AUDIO_CHANNELS=1         # 声道数

# Web 服务
WEB_HOST=0.0.0.0
WEB_PORT=5000
SECRET_KEY=change_this_to_random_string

# 天气查询 console.qweather.com
QATHER_API_KEY=c714c6c967e247e58306c759aa41b182
QATHER_ID=IDTNPKF4P5UR

